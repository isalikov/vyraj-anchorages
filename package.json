{
  "name": "vyraj",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite-ssg build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "lefthook install",
    "hook:install": "lefthook install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify": "pnpm lint && pnpm build && pnpm test",
    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@unhead/vue": "^2.1.15",
    "@unocss/reset": "^66.6.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^27.3.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "unhead": "2.1.15",
    "unocss": "^66.6.6",
    "vite": "^8.0.0",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.0.8",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}
